{
  "jira": {
    "url":   "https://your-domain.atlassian.net",
    "email": "your-email@example.com",
    "token": "your-api-token"
  },
  "project": {
    "key":    "PROJ",
    "output": "jira_hierarchy.xlsx"
  },
  "fields": {
    "story_points": ["customfield_10016", "customfield_10028"],
    "start_date":   ["customfield_10015", "startDate"],
    "due_date":     ["duedate", "customfield_10021"],
    "epic_link":    ["customfield_10014"]
  },
  "custom_fields": [
    {
      "id":    "customfield_10050",
      "label": "Team",
      "type":  "text",
      "width": 20
    },
    {
      "id":    "customfield_10060",
      "label": "Release Version",
      "type":  "text",
      "width": 18
    },
    {
      "id":    "customfield_10070",
      "label": "Risk Level",
      "type":  "text",
      "width": 14
    },
    {
      "id":    "customfield_10080",
      "label": "Reviewed By",
      "type":  "user",
      "width": 22
    },
    {
      "id":    "customfield_10090",
      "label": "Target Date",
      "type":  "date",
      "width": 14
    }
  ],
  "fetch": {
    "max_results":  100,
    "timeout_secs": 30
  },
  "logging": {
    "level": "INFO",
    "file":  "jira_extractor.log"
  }
}
